{
  "name": "puschelz-client",
  "productName": "Puschelz Client",
  "version": "0.1.30",
  "description": "Puschelz desktop tray client for WoW addon sync",
  "main": "dist/main.js",
  "scripts": {
    "test": "vitest run src/**/*.test.ts",
    "clean": "node scripts/fs-tasks.cjs clean-dist",
    "clean:release": "node scripts/fs-tasks.cjs clean-release",
    "copy:renderer": "node scripts/fs-tasks.cjs copy-renderer",
    "build": "npm run clean && tsc -p tsconfig.json && npm run copy:renderer",
    "package": "npm run build && npm run clean:release && electron-forge package",
    "make": "npm run build && npm run clean:release && electron-forge make",
    "dist": "npm run build && npm run clean:release && electron-builder --win nsis --publish onTagOrDraft",
    "start": "npm run build && electron-forge start",
    "dev": "npm run start",
    "test:watch": "vitest src/**/*.test.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/puschelz/puschelz-client.git"
  },
  "keywords": [],
  "author": "Puschelz",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/puschelz/puschelz-client/issues"
  },
  "homepage": "https://github.com/puschelz/puschelz-client#readme",
  "private": true,
  "config": {
    "forge": "./forge.config.js"
  },
  "build": {
    "appId": "com.puschelz.client",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "puschelz",
        "repo": "puschelz-client"
      }
    ],
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": false,
      "createStartMenuShortcut": false,
      "shortcutName": "Puschelz Client",
      "include": "build/installer.nsh"
    }
  },
  "dependencies": {
    "chokidar": "^5.0.0",
    "electron-updater": "^6.6.2",
    "fast-glob": "^3.3.3",
    "luaparse": "^0.3.1"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@types/node": "^25.2.3",
    "electron": "^40.4.1",
    "electron-builder": "^26.0.12",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
